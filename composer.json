{
	"name": "codekandis/phpunit",
	"description": "`codekandis/phpunit` is a library providing an enhanced test case wrapper with additional constraint assertions for `PhpUnit`.",
	"keywords": [
		"php",
		"library",
		"phpunit",
		"wrapper",
		"helper",
		"classes"
	],
	"minimum-stability": "stable",
	"prefer-stable": true,
	"license": "MIT",
	"authors": [
		{
			"name": "Christian Ramelow",
			"email": "info@codekandis.net",
			"homepage": "https://codekandis.net",
			"role": "Developer"
		}
	],
	"support": {
		"email": "info@codekandis.net",
		"issues": "https://github.com/codekandis/phpunit/issues",
		"docs": "https://github.com/codekandis/phpunit/blob/master/README.md",
		"source": "https://github.com/codekandis/phpunit/tree/master"
	},
	"require": {
		"php": "^8.5",
		"phpunit/phpunit": "^13.1.10"
	},
	"require-dev": {
		"roave/security-advisories": "dev-master",
		"phpstan/phpstan": "^2.1.54",
		"rector/rector": "^2.4.3"
	},
	"autoload": {
		"psr-4": {
			"CodeKandis\\PhpUnit\\": [
				"src/"
			]
		}
	},
	"autoload-dev": {
		"psr-4": {
			"CodeKandis\\PhpUnit\\Tests\\": [
				"tests/"
			]
		}
	},
	"scripts": {
		"analyse": [
			"Composer\\Config::disableProcessTimeout",
			"./vendor/bin/phpstan analyse --configuration ./build/phpstan.neon"
		],
		"test": [
			"Composer\\Config::disableProcessTimeout",
			"/usr/bin/env php -d xdebug.mode=off ./vendor/bin/phpunit --configuration ./build/phpunit.xml --no-coverage"
		],
		"test-coverage": [
			"Composer\\Config::disableProcessTimeout",
			"/usr/bin/env php -d xdebug.mode=coverage ./vendor/bin/phpunit --configuration ./build/phpunit.xml"
		]
	}
}
