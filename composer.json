{
	"name": "codekandis/phpunit",
	"description": "`codekandis/phpunit` is a library providing several wrapper and helper classes for the package `PHPUnit`.",
	"version": "5.0.0",
	"keywords": [
		"php",
		"phpunit wrapper helper classes",
		"phpunit",
		"wrapper",
		"helper",
		"classes"
	],
	"minimum-stability": "stable",
	"prefer-stable": true,
	"license": "MIT",
	"authors": [
		{
			"name": "Christian Ramelow",
			"email": "info@codekandis.net",
			"homepage": "https://codekandis.net",
			"role": "Developer"
		}
	],
	"support": {
		"email": "info@codekandis.net",
		"issues": "https://github.com/codekandis/phpunit/issues",
		"docs": "https://github.com/codekandis/phpunit/blob/master/README.md",
		"source": "https://github.com/codekandis/phpunit/tree/master"
	},
	"require": {
		"php": ">=8.3",
		"dms/phpunit-arraysubset-asserts": "^0.5.0",
		"phpunit/phpunit": "^10.4.1"
	},
	"require-dev": {
		"roave/security-advisories": "dev-master",
		"rector/rector": "^0.18.5"
	},
	"autoload": {
		"psr-4": {
			"CodeKandis\\PhpUnit\\": [
				"src/"
			]
		}
	},
	"autoload-dev": {
		"psr-4": {
			"CodeKandis\\PhpUnit\\Build\\": [
				"build/"
			]
		}
	}
}
